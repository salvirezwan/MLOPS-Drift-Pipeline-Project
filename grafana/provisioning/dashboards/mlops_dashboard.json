{
  "title": "MLOps Pipeline Dashboard",
  "uid": "mlops-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(mlops_request_count_total[1m])",
          "legendFormat": "{{endpoint}} {{status_code}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Latency p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(mlops_request_latency_seconds_bucket[1m]))",
          "legendFormat": "p95 {{endpoint}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "Drift Score",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 0.1 },
            { "color": "red", "value": 0.15 }
          ]
        },
        "min": 0,
        "max": 1
      },
      "targets": [
        {
          "expr": "mlops_drift_score",
          "legendFormat": "Drift Score",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "Shadow Divergence Rate",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 0.1 },
            { "color": "red", "value": 0.25 }
          ]
        },
        "min": 0,
        "max": 1
      },
      "targets": [
        {
          "expr": "mlops_shadow_divergence_rate",
          "legendFormat": "Divergence Rate",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 5,
      "title": "Prediction Distribution",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "mlops_prediction_total",
          "legendFormat": "Class {{prediction}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(mlops_request_count_total)",
          "legendFormat": "Total",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 7,
      "title": "Model Version",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "mlops_model_version_info",
          "legendFormat": "v{{version}}",
          "datasource": "Prometheus"
        }
      ]
    }
  ]
}
